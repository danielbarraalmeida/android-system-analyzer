{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session-manifest.schema.json",
  "title": "V2SessionManifest",
  "description": "Top-level registry for a v2 interaction-driven exploration session.",
  "type": "object",
  "required": [
    "session_id", "started_utc", "device_serial",
    "home_capture_id", "stop_conditions", "stop_reason",
    "summary", "states", "transitions", "attempts"
  ],
  "additionalProperties": false,
  "properties": {
    "session_id":      { "type": "string" },
    "started_utc":     { "type": "string" },
    "finished_utc":    { "type": ["string", "null"] },
    "device_serial":   { "type": "string" },
    "home_capture_id": { "type": "string" },
    "stop_conditions": {
      "type": "object",
      "required": ["max_states", "max_transitions", "max_depth", "timeout_seconds", "settle_ms"],
      "additionalProperties": false,
      "properties": {
        "max_states":      { "type": "integer" },
        "max_transitions": { "type": "integer" },
        "max_depth":       { "type": "integer" },
        "timeout_seconds": { "type": "number" },
        "settle_ms":       { "type": "integer" }
      }
    },
    "stop_reason": {
      "type": "string",
      "enum": ["max_states", "max_transitions", "max_depth", "timeout", "queue_exhausted", "interrupted", "error"]
    },
    "summary": {
      "type": "object",
      "required": ["total_states", "total_transitions", "total_attempts", "total_failures"],
      "additionalProperties": false,
      "properties": {
        "total_states":      { "type": "integer" },
        "total_transitions": { "type": "integer" },
        "total_attempts":    { "type": "integer" },
        "total_failures":    { "type": "integer" }
      }
    },
    "states": {
      "type": "array",
      "items": { "$ref": "#/$defs/state" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition" }
    },
    "attempts": {
      "type": "array",
      "items": { "$ref": "#/$defs/attempt" }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "required": [
        "state_id", "state_signature", "package_name", "activity_name",
        "element_count", "candidate_count", "is_home_root", "depth", "visited_at_utc"
      ],
      "additionalProperties": false,
      "properties": {
        "state_id":        { "type": "string" },
        "state_signature": { "type": "string" },
        "package_name":    { "type": ["string", "null"] },
        "activity_name":   { "type": ["string", "null"] },
        "element_count":   { "type": "integer" },
        "candidate_count": { "type": "integer" },
        "is_home_root":    { "type": "boolean" },
        "depth":           { "type": "integer" },
        "visited_at_utc":  { "type": "string" }
      }
    },
    "transition": {
      "type": "object",
      "required": [
        "transition_id", "source_state_id", "source_element_id",
        "action_type", "action_payload",
        "destination_state_id", "outcome",
        "error", "started_utc", "finished_utc"
      ],
      "additionalProperties": false,
      "properties": {
        "transition_id":        { "type": "string" },
        "source_state_id":      { "type": "string" },
        "source_element_id":    { "type": "string" },
        "action_type":          { "type": "string", "enum": ["tap"] },
        "action_payload": {
          "type": "object",
          "required": ["x", "y", "element_path"],
          "additionalProperties": false,
          "properties": {
            "x":            { "type": "integer" },
            "y":            { "type": "integer" },
            "element_path": { "type": "string" }
          }
        },
        "destination_state_id": { "type": ["string", "null"] },
        "outcome":              { "type": "string", "enum": ["success", "no_change", "failed", "blocked"] },
        "error":                { "type": ["string", "null"] },
        "started_utc":          { "type": "string" },
        "finished_utc":         { "type": "string" }
      }
    },
    "attempt": {
      "type": "object",
      "required": [
        "attempt_id", "state_id", "element_id", "element_path",
        "action_type", "action_payload", "outcome",
        "skip_reason", "transition_id", "attempted_utc"
      ],
      "additionalProperties": false,
      "properties": {
        "attempt_id":    { "type": "string" },
        "state_id":      { "type": "string" },
        "element_id":    { "type": "string" },
        "element_path":  { "type": "string" },
        "action_type":   { "type": "string" },
        "action_payload": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" }
          }
        },
        "outcome":       { "type": "string", "enum": ["executed", "skipped", "blocked"] },
        "skip_reason":   { "type": ["string", "null"] },
        "transition_id": { "type": ["string", "null"] },
        "attempted_utc": { "type": "string" }
      }
    }
  }
}
